TELEGRAM_BOT_TOKEN=
# Только если PRICE_SOURCE=travelpayouts
TRAVELPAYOUTS_TOKEN=

# aviasales_screenshot — Playwright открывает страницу выдачи на Авиасейлс или Купибилет (выбор сайта у пользователя в «Настройках» бота).
# travelpayouts — партнёрский API Cheap (нужен токен выше)
PRICE_SOURCE=aviasales_screenshot

# Как часто тикает расписание подписок (мс)
PRICE_POLL_INTERVAL_MS=60000

# Как часто заново загружать страницу/API (тяжёлое)
FETCH_INTERVAL_MS=120000

# Интервал сводок для режима «Интервал» (мс), если пользователь не задал свой через команду /digest_ms
HOURLY_DIGEST_INTERVAL_MS=3600000

# Kupibilet: после открытия страницы — пауза перед чтением DOM (SPA), мс.
KUPIBILET_RENDER_WAIT_MS=9000
# Kupibilet: таймаут goto Playwright (мс)
KUPIBILET_GOTO_TIMEOUT_MS=120000
# Если true — JPEG на всю высоту (тяжелее), иначе только viewport
KUPIBILET_FULL_PAGE_SCREENSHOT=false

# Таймаут goto (мс), по умолчанию 120_000
# WAIT_UNTIL=domcontentloaded + пауза AVIASALES_RENDER_WAIT_MS ниже надёжнее, чем ждать полный «load»
# AVIASALES_GOTO_TIMEOUT_MS=120000

# После открытия URL (domcontentloaded) — пауза перед чтением DOM, мс; для SPA обычно 5000–10000.
AVIASALES_RENDER_WAIT_MS=8000

# Если true — JPEG на всю высоту страницы (тяжелее), иначе только viewport
AVIASALES_FULL_PAGE_SCREENSHOT=false

# При отправке скрина выдачи (настройка «со скрином»): графическая панель с маршрутом · даты · перевозчики поверх нижней части JPEG
FLIGHT_DIGEST_CARD_OVERLAY=true

# Опционально: стикер = file_id ЭТОГО бота (отправь стикер своему боту → возьми file_id из апдейта; чужие боты не подходят).
# Или прямой https://… на .webp (статичный). Анимация = file_id или https (как для sendAnimation).
# TELEGRAM_STICKER_CHECKING=...
# Короткая «подождите» при интервале «Пора проверить»
# TELEGRAM_STICKER_WAIT=...
# Реакция после успешной подписки (исчезает через несколько секунд)
# TELEGRAM_STICKER_SUCCESS=...
# Короткая анимация (mp4 или gif как file_id / прямой URL, если поддерживает Bot API)
# TELEGRAM_ANIMATION_LOADING=...

PLAYWRIGHT_HEADLESS=true
# Установи Google Chrome и укажи chrome — меньше «роботских» отпечатков, чем у чистого Chromium.
# PLAYWRIGHT_CHANNEL=chrome

# Файл с куками после ручного прохода капчи: npm run aviasales:auth
# PLAYWRIGHT_STORAGE_STATE_PATH=./aviasales-storage.json

PORT=3000
